# Hurl secrets file for nimaproxy e2e tests
# Usage: hurl --test --secrets-file scripts/tests/.hurl.config scripts/tests/*.hurl

# API Keys (sourced from .env, but can be overridden here)
# NIMAPROXY_KEY_DOLTARES: {{doltares_key}}
# NIMAPROXY_KEY_ARES: {{ares_key}}

# nimaproxy endpoint
NIMAPROXY_URL: http://127.0.0.1:8080

# Test model IDs
TEST_MODEL_AUTO: auto
TEST_MODEL_MISTRAL_SMALL: mistralai/mistral-small-4-119b-2603
TEST_MODEL_MISTRAL_LARGE: mistralai/mistral-large-3-675b-instruct-2512
TEST_MODEL_DEVSTRAL: mistralai/devstral-2-123b-instruct-2512
TEST_MODEL_QWEN: qwen/qwen3.5-122b-a10b
TEST_MODEL_GLM: z-ai/glm4.7

# Test keys (short hints for logging)
TEST_KEY_HINT_DOLTARES: ...rTjG
TEST_KEY_HINT_ARES: ...xmIw
TEST_KEY_HINT_BACKUP: ...didJ
TEST_KEY_HINT_EXTRA: ...Il0Y
