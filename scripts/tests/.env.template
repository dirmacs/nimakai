# Nimaproxy Test Environment Variables
# Copy to /opt/nimakai/scripts/tests/.env and fill in your values

# NVIDIA API Keys (nimaproxy uses these)
# Format: one per line, same as nimaproxy.toml labels
NIMAPROXY_KEY_DOLTARES=nvapi-REDACTED_DOLTARES_KEY
NIMAPROXY_KEY_ARES=nvapi-REDACTED_ARES_KEY
NIMAPROXY_KEY_BACKUP=nvapi-REDACTED_BACKUP_KEY
NIMAPROXY_KEY_EXTRA=nvapi-REDACTED_EXTRA_KEY

# nimaproxy endpoint
NIMAPROXY_URL=http://127.0.0.1:8080

# Test configuration
TEST_TIMEOUT_MS=15000
TEST_RACING_TIMEOUT_MS=15000
