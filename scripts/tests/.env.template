# Nimaproxy Test Environment Variables
# Copy to scripts/tests/.env and fill in your values

# NVIDIA API Keys — add one entry per key you have (labels are arbitrary)
# Use the same labels in nimaproxy.toml [[keys]] section
# Format matches nimaproxy.toml.example: nvapi-YOUR_KEY_HERE style
NIMAPROXY_KEY_1=nvapi-YOUR_FIRST_KEY_HERE
NIMAPROXY_KEY_2=nvapi-YOUR_SECOND_KEY_HERE
NIMAPROXY_KEY_3=nvapi-YOUR_THIRD_KEY_HERE
NIMAPROXY_KEY_4=nvapi-YOUR_FOURTH_KEY_HERE

# nimaproxy endpoint
NIMAPROXY_URL=http://127.0.0.1:8080

# Test configuration
TEST_TIMEOUT_MS=15000
TEST_RACING_TIMEOUT_MS=15000
