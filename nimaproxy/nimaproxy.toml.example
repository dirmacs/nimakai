# nimaproxy — NVIDIA NIM Key-Rotation Proxy
# ================================================================
# Copy this to nimaproxy.toml and fill in your keys.
# Then run: ./nimaproxy --config ./nimaproxy.toml
#
# All fields are optional except [[keys]] — at least one key is required.

# Local address to bind. Defaults to 127.0.0.1:8080.
# listen = "127.0.0.1:8080"

# Upstream NVIDIA NIM target. Defaults to https://integrate.api.nvidia.com.
# target = "https://integrate.api.nvidia.com"

# ── API Keys ────────────────────────────────────────────────────────────────
# Each key's RPM budget (40 RPM) pools together via round-robin rotation.
# On 429, the proxy cools down the rate-limited key and retries with the next.
# Any number of keys can be added. Keys rotate in order.

[[keys]]
key = "nvapi-YOUR_FIRST_KEY_HERE"
label = "key1"

[[keys]]
key = "nvapi-YOUR_SECOND_KEY_HERE"
label = "key2"

[[keys]]
key = "nvapi-YOUR_THIRD_KEY_HERE"
label = "key3"

[[keys]]
key = "nvapi-YOUR_FOURTH_KEY_HERE"
label = "key4"

# ── Latency-Aware Model Routing ──────────────────────────────────────────────
# When a request arrives with `"model": "auto"`, the proxy picks the best
# model from this list using real-time TTFC stats.
#
# Untried models (< 3 samples) get priority. Degraded models (≥3 consecutive
# failures or avg TTFC > spike_threshold_ms) are skipped until they recover.
#
# [routing]
# strategy           = "latency_aware"
# spike_threshold_ms = 3000
#
# models = [
#   "moonshotai/kimi-k2-instruct",
#   "qwen/qwen2.5-coder-32b-instruct",
#   "mistralai/devstral-2-123b-instruct-2512",
#   "meta/llama-3.3-70b-instruct",
# ]

# ── Model Racing (Speculative Execution) ──────────────────────────────────
# Fire N parallel requests to N models, return first response.
# Trades N×token budget for min(P50 latency).
# Dead models (≥20 consecutive failures, 0 samples, or degraded) are filtered
# automatically. Keys are pre-allocated per task to avoid 429 collisions.
#
# [racing]
# enabled = true
# models = [
#   "moonshotai/kimi-k2",
#   "minimaxai/minimax-m2.5",
#   "qwen/qwen3-next-80b-a3b-thinking",
#   "stepfun-ai/step-3.5-flash",
#   "qwen/qwen3.5-122b-a10b",
#   "qwen/qwen3-coder-480b-a35b-instruct",
#   "google/gemma-3-27b-it",
#   "qwen/qwen2.5-coder-32b-instruct",
# ]
# max_parallel = 8
# timeout_ms = 15000
# strategy = "complete"
